rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidAd(data) {
      return data.keys().hasAll(['title', 'price', 'category', 'sellerId', 'createdAt', 'status'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 50
        && data.sellerId == request.auth.uid
        && data.status in ['active', 'sold', 'deleted']
        && (data.get('description', '') is string && data.get('description', '').size() <= 2000)
        && (data.get('images', []) is list && data.get('images', []).size() <= 10)
        && (data.get('whatsappNumber', '') is string && data.get('whatsappNumber', '').size() <= 20)
        && (data.get('sellerName', '') is string && data.get('sellerName', '').size() <= 100);
    }

    function isValidUser(data) {
       return data.keys().hasAll(['displayName', 'email'])
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.get('whatsappNumber', '') is string && data.get('whatsappNumber', '').size() <= 20)
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500);
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'adId', 'lastMessageAt'])
        && data.participants is list && data.participants.size() == 2
        && request.auth.uid in data.participants
        && data.adId is string
        && (data.get('adTitle', '') is string && data.get('adTitle', '').size() <= 100)
        && (data.get('lastMessage', '') is string && data.get('lastMessage', '').size() <= 500);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.createdAt == request.time;
    }

    // Collection Rules
    match /ads/{adId} {
      allow get: if true;
      allow list: if true; 
      
      allow create: if isVerified() 
        && isValidId(adId) 
        && isValidAd(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isVerified()
        && (
          (existing().sellerId == request.auth.uid && isValidAd(incoming()) && (
            // Action: Edit Ad info or Change status
            incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'condition', 'images', 'location', 'contactMethod', 'whatsappNumber', 'status', 'sellerName'])
          )) || isAdmin()
        );
        
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isVerified() 
          && isValidId(commentId)
          && incoming().userId == request.auth.uid
          && incoming().text is string && incoming().text.size() > 0 && incoming().text.size() <= 1000
          && incoming().createdAt == request.time;
      }
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if true; 
      
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'whatsappNumber', 'fcmToken']))
        || isAdmin()
      );
    }

    match /users/{userId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() 
        && isValidId(reviewId)
        && userId != request.auth.uid 
        && incoming().fromUserId == request.auth.uid
        && incoming().toUserId == userId
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && incoming().createdAt == request.time;
      
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && existing().fromUserId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      allow create: if isVerified() 
        && isValidId(chatId) 
        && isValidChat(incoming())
        && incoming().lastMessageAt == request.time;
        
      allow update: if isSignedIn() 
        && request.auth.uid in existing().participants
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'unreadCount'])
          || isAdmin()
        );

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isVerified() 
          && isValidId(messageId)
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isValidMessage(incoming());
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
